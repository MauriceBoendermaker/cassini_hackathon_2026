# Copy this file to .env and fill in the values.
# All variables must be prefixed with VITE_ to be accessible in the app.

# Map tiles — get a free key at https://cloud.maptiler.com (100k loads/month free)
# Leave empty to fall back to OSM (dev only — OSM prohibits production use)
VITE_MAPTILER_API_KEY=

# Backend API (defaults to http://localhost:8000 when unset)
VITE_API_BASE_URL=

# Copernicus Emergency Management Service
VITE_COPERNICUS_API_URL=
VITE_COPERNICUS_API_KEY=

# Galileo / GNSS positioning service
VITE_GALILEO_API_URL=
VITE_GALILEO_API_KEY=
